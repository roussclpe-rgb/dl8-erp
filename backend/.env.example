PORT=3001

# Obligatorio. Genera un valor local con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# No copies un secreto real a este archivo ni lo subas a Git.
JWT_SECRET=

# Ruta del archivo SQLite. Relativa a la raíz del proyecto.
DB_PATH=./data.sqlite

# Orígenes permitidos para CORS, separados por coma (ej: https://miapp.com,https://otra.com)
# Si se deja vacío, CORS queda abierto (solo recomendado para desarrollo local).
CORS_ORIGINS=http://localhost:5173

# development | production
NODE_ENV=development
