PORT=3001

# Genera algo largo y aleatorio, por ejemplo con: openssl rand -hex 32
JWT_SECRET=cambia-esto-en-produccion

# Ruta del archivo SQLite. Relativa a la raíz del proyecto.
DB_PATH=./data.sqlite

# Orígenes permitidos para CORS, separados por coma (ej: https://miapp.com,https://otra.com)
# Si se deja vacío, CORS queda abierto (solo recomendado para desarrollo local).
CORS_ORIGINS=

# development | production
NODE_ENV=development
